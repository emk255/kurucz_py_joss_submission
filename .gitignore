# Logs
*.log
logs/
fortran_debug_*.log
*_debug.log

# NPZ files - ignore outputs and temporary files, but keep essential data tables
# Ignore output directories
synthe_py/out/*.npz
out/*.npz

# Ignore user-generated atmosphere files (these are converted from .atm files)
synthe_py/data/at12_*.npz
synthe_py/data/*_atmosphere*.npz
synthe_py/data/fort*.npz
synthe_py/data/tmp_*.npz

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Numba cache
*.nbc
*.nbi

# Compiled executables
bin/*.exe
*.exe

# Fortran build artifacts
*.o
*.mod
*.a
compile.log

# Fortran temporary output files (stmp directories contain large fort.* files)
synthe/stmp_*/
synthe/*/fort.*

# Temporary files
*.tmp
*.temp
.DS_Store

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test executables
tests/*_exact
tests/*.exe

# Intel oneAPI files
intel.*.dot
intel.sessionmanifest.*.json